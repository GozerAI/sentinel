# Sentinel Security Platform - Environment Variables
# Copy this to .env and fill in your values

# =============================================================================
# Database
# =============================================================================
DB_PASSWORD=your-secure-password

# =============================================================================
# Router Integration (OPNsense/pfSense)
# =============================================================================
ROUTER_API_KEY=your-router-api-key
ROUTER_API_SECRET=your-router-api-secret

# =============================================================================
# Switch Integration (UniFi)
# =============================================================================
UNIFI_USER=your-unifi-username
UNIFI_PASSWORD=your-unifi-password

# =============================================================================
# Hypervisor Integration (Proxmox)
# =============================================================================
PROXMOX_TOKEN_NAME=sentinel
PROXMOX_TOKEN_VALUE=your-proxmox-token

# =============================================================================
# Storage Integration (TrueNAS)
# =============================================================================
TRUENAS_API_KEY=your-truenas-api-key

# =============================================================================
# LLM Integration
# =============================================================================
# Anthropic (fallback for complex decisions)
ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================================
# API Security
# =============================================================================
API_SECRET_KEY=your-jwt-secret-key-change-in-production

# =============================================================================
# Alerting (Optional)
# =============================================================================
PUSHOVER_USER_KEY=your-pushover-user-key
PUSHOVER_API_TOKEN=your-pushover-api-token

# =============================================================================
# Grafana
# =============================================================================
GRAFANA_PASSWORD=your-grafana-admin-password
